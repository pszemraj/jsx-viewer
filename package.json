{
  "name": "jsx-viewer",
  "version": "1.0.0",
  "description": "Drop-in viewer for JSX/TSX React component files. Make .jsx and .tsx as portable as .html.",
  "type": "module",
  "bin": {
    "jsx-viewer": "./bin/jsx-viewer.mjs"
  },
  "scripts": {
    "dev": "node bin/jsx-viewer.mjs",
    "start": "node bin/jsx-viewer.mjs",
    "demo": "node bin/jsx-viewer.mjs example/Dashboard.tsx",
    "guard:slot": "node --import tsx ./bin/check-slot.ts",
    "slot:reset": "node --import tsx ./bin/check-slot.ts --fix",
    "build": "vite build",
    "test": "node --import tsx --test src/slotComponent.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepare": "node --import tsx ./bin/setup-hooks.ts"
  },
  "keywords": [
    "jsx",
    "react",
    "viewer",
    "preview",
    "component"
  ],
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.4.3",
    "chokidar": "^3.6.0",
    "d3": "^7.9.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.383.0",
    "mathjs": "^13.0.3",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "three": "^0.164.1",
    "tone": "^15.0.4",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jiti": "^2.6.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
