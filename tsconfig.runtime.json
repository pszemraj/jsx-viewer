{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "bin/**/*.mjs",
    "shared/**/*.mjs"
  ],
  "exclude": [
    "**/*.test.mjs"
  ]
}
